{
  "files.associations": {
    "*.tl": "tinylang",
    "*.tlc": "binary"
  },
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/compiler/frontend",
    "${workspaceFolder}/compiler/middleend",
    "${workspaceFolder}/compiler/backend",
    "${workspaceFolder}/compiler/common",
    "${workspaceFolder}/runtime/vm"
  ],
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.compilerPath": "/usr/bin/g++",
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "files.exclude": {
    "tinylang": true,
    "**/*.tlc": true,
    "**/*.o": true
  },
  "search.exclude": {
    "**/*.tlc": true,
    "tools/vscode-extension/*.vsix": true
  }
}
